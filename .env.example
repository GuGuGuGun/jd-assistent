# ═══ LLM 配置 ═══
LLM_PROVIDER=openai                  # openai / anthropic / google
LLM_MODEL=gpt-4o                    # 模型名称
LLM_API_KEY=sk-your-api-key-here                # API Key
LLM_BASE_URL=https://yunwu.ai/v1                       # 自定义 API 端点（可选）
LLM_TEMPERATURE=0.3                 # 温度参数（建议 0.2-0.4）
LLM_MAX_TOKENS=4096                 # 单次最大输出 Token
LLM_REQUEST_TIMEOUT_SECONDS=30      # 单次 LLM 请求超时秒数
LLM_FALLBACK_PROVIDERS=anthropic:claude-3-5-sonnet,google:gemini-1.5-pro  # 主模型失败时的兜底链

# ═══ 服务配置 ═══
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./jd_assistent.db  # 本地默认数据库；Docker Compose 可改为 ./data/jd_assistent.db
ALEMBIC_DATABASE_URL=sqlite:///./jd_assistent.db    # Alembic 使用同步驱动地址

# ═══ 认证配置 ═══
JWT_SECRET=dev-jwt-secret-change-me    # 开发环境示例值，生产环境必须替换
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
ADMIN_EMAILS=                         # 多个管理员邮箱用逗号分隔

# ═══ 任务派发配置 ═══
TASK_DISPATCHER_MODE=local             # local / celery；若希望 Worker 跨进程持续执行，必须改为 celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ═══ SSE 事件传输配置 ═══
SSE_EVENT_BUS_BACKEND=memory        # memory / redis；若前后端/worker 分进程部署，建议改为 redis
REDIS_URL=redis://127.0.0.1:6379/0  # 未设置时会自动复用 CELERY_BROKER_URL
SSE_REDIS_CHANNEL_PREFIX=jd-assistent:sse

# ═══ LangGraph Checkpoint 配置 ═══
LANGGRAPH_CHECKPOINT_BACKEND=memory                 # memory / redis；若需要跨进程恢复执行，建议改为 redis
LANGGRAPH_CHECKPOINT_REDIS_URL=redis://127.0.0.1:6379/0
LANGGRAPH_CHECKPOINT_REDIS_KEY_PREFIX=jd-assistent:checkpoint

# 说明：
# 1. 纯本地开发可保留 local + memory，配置最少，但任务恢复能力仅限单进程场景。
# 2. 若希望“新建任务后切页再回来”仍可稳定追踪跨进程执行，推荐使用以下组合：
#    TASK_DISPATCHER_MODE=celery
#    SSE_EVENT_BUS_BACKEND=redis
#    LANGGRAPH_CHECKPOINT_BACKEND=redis
